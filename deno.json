{
  "name": "@justn-hyeok/git-roast",
  "version": "0.2.0",
  "license": "MIT",
  "exports": "./main.ts",
  "tasks": {
    "dev": "deno run --allow-run --allow-net --allow-read --allow-env main.ts",
    "test": "deno test --allow-run --allow-read",
    "lint": "deno lint",
    "fmt": "deno fmt",
    "compile": "deno compile --allow-run --allow-net --allow-read --allow-env --output=git-roast main.ts",
    "coverage": "deno test --allow-run --allow-read --coverage=cov_profile && deno coverage cov_profile"
  },
  "imports": {
    "@std/cli": "jsr:@std/cli@^1",
    "@std/fmt": "jsr:@std/fmt@^1",
    "@std/testing": "jsr:@std/testing@^1",
    "@std/assert": "jsr:@std/assert@^1"
  }
}
